import pandas as pd
from pathlib import Path

configfile: "workflow.yaml"

ACTIVE_STAGE = config["active"]["stage"]
ACTIVE_STEPS = config["active"]["steps"]

if config.get("container"):
    container: config["container"]

SUBCFG = config["stages"][ACTIVE_STAGE]
EXP    = SUBCFG["exp"]
CSV    = SUBCFG["csv"]

if not Path(CSV).exists():
    raise WorkflowError(
        f"Summary CSV not found: {CSV}\n"
        f"Generate it first by running the corresponding sweep script, e.g.:\n"
        f"  python sweeps/simulation/e0/sweep.py"
    )

_df = pd.read_csv(CSV)


def _clean(v):
    """Return None for NaN (empty CSV cells); pass everything else through."""
    try:
        return None if pd.isna(v) else v
    except (TypeError, ValueError):
        return v


params_by_path = {
    row["short_path"]: {k: _clean(v) for k, v in row.to_dict().items()}
    for _, row in _df.iterrows()
}

instances = list(range(1, config["num_instances"] + 1))

include: "rules/simulate.smk"
include: "rules/aggregate.smk"


onstart:
    print("\n--- Analysis started ---\n")


onsuccess:
    print("\n--- Workflow finished! ---\n")


onerror:
    print("\n--- An error occurred! ---\n")


def _all_targets():
    targets = []
    if "simulate" in ACTIVE_STEPS:
        targets += expand(
            f"data/{ACTIVE_STAGE}/{EXP}/{{path}}/{{instance}}/results.json",
            path=_df["short_path"],
            instance=instances,
        )
    if "aggregate" in ACTIVE_STEPS:
        targets += [f"results/{ACTIVE_STAGE}/{EXP}/results.csv"]
    return targets


rule all:
    input:
        _all_targets()
